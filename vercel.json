{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/2026/index.html" },
    { "source": "/((?!2025|2026|api|_next|favicon|module-runtime|feedback-widget|platform|styles).*\\.html)", "destination": "/2026/$1" },
    { "source": "/((?!2025|2026|api|_next|favicon|module-runtime|feedback-widget|platform|styles)[^./]+)$", "destination": "/2026/$1.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/(module-runtime|feedback-widget|platform|styles)\\.(js|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
